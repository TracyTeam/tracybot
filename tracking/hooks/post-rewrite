#!/usr/bin/env bash
set -euo pipefail

# Git passes "amend" or "rebase" as the first argument.
REWRITE_TYPE="${1:-rebase}"

REF_BASE_PUSHED="refs/tracy"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

get_tracy_ids_from_note() {
    local note="$1"
    echo "$note" | grep -oE 'tracy-id: [a-f0-9@-]+' | cut -d' ' -f2 || true
}

get_chain_commits_oldest_first() {
    local tracy_id="$1"
    local ref="$REF_BASE_PUSHED/$tracy_id"

    if ! git rev-parse --verify "$ref" >/dev/null 2>&1; then
        return
    fi

    # When the tracy_id carries a commit hash (uuid@hash), use the parent of
    # that commit as the hard stop.  This stays correct even after a squash
    # rebase where the old user commits are no longer reachable from any
    # branch and therefore not excluded by --not --branches.
    local exclude_ref=""
    if [[ "$tracy_id" == *"@"* ]]; then
        local short_hash="${tracy_id##*@}"
        exclude_ref=$(git rev-parse --verify "${short_hash}^" 2>/dev/null || true)
    fi

    local commits
    if [[ -n "$exclude_ref" ]]; then
        commits=$(git log --format="%H" "$ref" --not "$exclude_ref" 2>/dev/null || true)
    else
        commits=$(git log --format="%H" "$ref" --not --branches --not --tags 2>/dev/null || true)
    fi

    local reversed=""
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        reversed="$line"$'\n'"$reversed"
    done <<< "$commits"
    echo "${reversed%$'\n'}"
}

delete_chain() {
    local tracy_id="$1"
    git update-ref -d "$REF_BASE_PUSHED/$tracy_id" 2>/dev/null || true
    git config --unset "tracy.$tracy_id.hidden" 2>/dev/null || true
}

collect_commits_for_ids() {
    local tracy_ids="$1"
    local result=""

    while IFS= read -r tid; do
        [[ -z "$tid" ]] && continue
        local chain
        chain=$(get_chain_commits_oldest_first "$tid")
        [[ -n "$chain" ]] && result+="$chain"$'\n'
    done <<< "$tracy_ids"

    echo "${result%$'\n'}"
}

delete_chains_for_ids() {
    local tracy_ids="$1"
    while IFS= read -r tid; do
        [[ -z "$tid" ]] && continue
        delete_chain "$tid"
    done <<< "$tracy_ids"
}

build_chain_from_commits() {
    local commits_list="$1"
    local origin_commit="${2:-}"
    local deduped_commits
    local parent="$origin_commit" 
    local new_tip=""

    deduped_commits=$(printf '%s\n' "$commits_list" | awk 'NF && !seen[$0]++')

    while IFS= read -r commit; do
        [[ -z "$commit" ]] && continue

        local commit_tree
        commit_tree=$(git rev-parse "$commit^{tree}" 2>/dev/null || true)
        [[ -z "$commit_tree" ]] && continue

        local msg
        msg=$(git log -1 --format='%B' "$commit" 2>/dev/null || true)

        local meta_str
        meta_str=$(git log -1 --format='%an%n%ae%n%aI%n%cn%n%ce%n%cI' "$commit" 2>/dev/null || true)

        local author_name author_email author_date committer_name committer_email committer_date
        author_name=$(printf '%s\n' "$meta_str" | sed -n '1p')
        author_email=$(printf '%s\n' "$meta_str" | sed -n '2p')
        author_date=$(printf '%s\n' "$meta_str" | sed -n '3p')
        committer_name=$(printf '%s\n' "$meta_str" | sed -n '4p')
        committer_email=$(printf '%s\n' "$meta_str" | sed -n '5p')
        committer_date=$(printf '%s\n' "$meta_str" | sed -n '6p')

        local new_commit
        if [[ -n "$author_date" && -n "$committer_date" ]]; then
            new_commit=$(
                GIT_AUTHOR_NAME="$author_name"         \
                GIT_AUTHOR_EMAIL="$author_email"        \
                GIT_AUTHOR_DATE="$author_date"          \
                GIT_COMMITTER_NAME="$committer_name"    \
                GIT_COMMITTER_EMAIL="$committer_email"  \
                GIT_COMMITTER_DATE="$committer_date"    \
                git commit-tree ${parent:+-p "$parent"} "$commit_tree" \
                    -m "${msg:-tracy snapshot}" 2>/dev/null || true
            )
        else
            new_commit=$(
                GIT_AUTHOR_NAME="${author_name:-Tracybot}"         \
                GIT_AUTHOR_EMAIL="${author_email:-tracybot@local}"  \
                GIT_COMMITTER_NAME="${committer_name:-Tracybot}"    \
                GIT_COMMITTER_EMAIL="${committer_email:-tracybot@local}" \
                git commit-tree ${parent:+-p "$parent"} "$commit_tree" \
                    -m "${msg:-tracy snapshot}" 2>/dev/null || true
            )
        fi

        if [[ -n "$new_commit" ]]; then
            parent="$new_commit"
            new_tip="$new_commit"
        fi
    done <<< "$deduped_commits"

    echo "$new_tip"
}

# Create a refs/tracy chain from a commits list and attach it to a commit's note.
publish_chain() {
    local all_commits="$1"
    local target_sha="$2"

    [[ -z "$all_commits" ]] && return

    local NEW_UUID
    NEW_UUID=$(uuidgen | tr '[:upper:]' '[:lower:]')

    local SHORT_HASH
    SHORT_HASH=$(git rev-parse --short=8 "$target_sha" 2>/dev/null || true)

    local FINAL_ID="$NEW_UUID"
    [[ -n "$SHORT_HASH" ]] && FINAL_ID="$NEW_UUID@$SHORT_HASH"

    local new_origin
    new_origin=$(git rev-parse --verify "$target_sha^" 2>/dev/null || true)

    local new_tip
    new_tip=$(build_chain_from_commits "$all_commits" "$new_origin")

    if [[ -n "$new_tip" ]]; then
        git update-ref "$REF_BASE_PUSHED/$FINAL_ID" "$new_tip"
        git config "tracy.$FINAL_ID.hidden" "$new_tip"
        git notes add -f -m "tracy-id: $FINAL_ID" "$target_sha" 2>/dev/null || true
    fi
}

# amend: post-commit already created a new chain on new_sha; prepend the old
# chain (pre-amend history) to it, then publish a single combined chain.
# Old chains are intentionally kept so the user can reset to them.
handle_amend() {
    local old_sha="$1"
    local new_sha="$2"

    local old_note new_note
    old_note=$(git notes show "$old_sha" 2>/dev/null || true)
    new_note=$(git notes show "$new_sha" 2>/dev/null || true)

    local old_ids new_ids
    old_ids=$(get_tracy_ids_from_note "$old_note")
    new_ids=$(get_tracy_ids_from_note "$new_note")

    local old_commits new_commits all_commits=""
    old_commits=$(collect_commits_for_ids "$old_ids")
    new_commits=$(collect_commits_for_ids "$new_ids")
    [[ -n "$old_commits" ]] && all_commits+="$old_commits"$'\n'
    [[ -n "$new_commits" ]] && all_commits+="$new_commits"$'\n'
    all_commits="${all_commits%$'\n'}"

    publish_chain "$all_commits" "$new_sha"
}

# rebase (one-to-one): publish the old chain under a fresh ID for the new SHA.
# Old chain is intentionally kept so the user can reset to it.
handle_rebase() {
    local old_sha="$1"
    local new_sha="$2"

    local old_note
    old_note=$(git notes show "$old_sha" 2>/dev/null || true)
    local old_ids
    old_ids=$(get_tracy_ids_from_note "$old_note")

    [[ -z "$old_ids" ]] && return

    local all_commits
    all_commits=$(collect_commits_for_ids "$old_ids")

    publish_chain "$all_commits" "$new_sha"
}

# squash: merge chains from all old SHAs into a single chain attached to new_sha.
# Old chains are intentionally kept so the user can reset to them.
# The chain post-commit may have placed on new_sha during the rebase is ignored:
# it is always a duplicate of one of the old chains (rebase fires post-commit
# for intermediate squash steps using whatever session was active at the time).
handle_squash() {
    local new_sha="$1"
    local old_shas_str="$2"

    local all_commits=""

    # git may report rewrite pairs in any order; sort by author timestamp so
    # chains are concatenated chronologically (oldest commit first).
    local sorted_old_shas
    sorted_old_shas=$(while IFS= read -r sha; do
        [[ -z "$sha" ]] && continue
        local ts
        ts=$(git log -1 --format='%at' "$sha" 2>/dev/null || echo 0)
        printf '%s %s\n' "$ts" "$sha"
    done <<< "$old_shas_str" | sort -n | awk '{print $2}')

    while IFS= read -r old_sha; do
        [[ -z "$old_sha" ]] && continue
        local old_note
        old_note=$(git notes show "$old_sha" 2>/dev/null || true)
        local old_ids
        old_ids=$(get_tracy_ids_from_note "$old_note")

        local old_commits
        old_commits=$(collect_commits_for_ids "$old_ids")
        [[ -n "$old_commits" ]] && all_commits+="$old_commits"$'\n'
    done <<< "$sorted_old_shas"

    all_commits="${all_commits%$'\n'}"

    publish_chain "$all_commits" "$new_sha"
}

# Buffer all pairs as "old:new" strings
declare -a all_pairs=()
while read -r old_sha new_sha; do
    [[ -z "$old_sha" || -z "$new_sha" ]] && continue
    all_pairs+=("$old_sha:$new_sha")
done

# Collect unique new_shas in insertion order.
declare -a new_shas_ordered=()
for pair in ${all_pairs[@]+"${all_pairs[@]}"}; do
    new_sha="${pair#*:}"
    already_seen=false
    for seen in ${new_shas_ordered[@]+"${new_shas_ordered[@]}"}; do
        [[ "$seen" == "$new_sha" ]] && already_seen=true && break
    done
    $already_seen || new_shas_ordered+=("$new_sha")
done

for new_sha in ${new_shas_ordered[@]+"${new_shas_ordered[@]}"}; do
    old_shas_str=""
    for pair in ${all_pairs[@]+"${all_pairs[@]}"}; do
        [[ "${pair#*:}" != "$new_sha" ]] && continue
        [[ -n "$old_shas_str" ]] && old_shas_str+=$'\n'
        old_shas_str+="${pair%:*}"
    done

    old_count=$(printf '%s\n' "$old_shas_str" | grep -c '[^[:space:]]' || true)

    if [[ "$old_count" -gt 1 ]]; then
        handle_squash "$new_sha" "$old_shas_str"
    elif [[ "$REWRITE_TYPE" == "amend" ]]; then
        handle_amend "$old_shas_str" "$new_sha"
    else
        handle_rebase "$old_shas_str" "$new_sha"
    fi
done
