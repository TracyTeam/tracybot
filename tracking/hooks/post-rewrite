#!/usr/bin/env bash
set -euo pipefail

# Used OpenCode's big-pickle model to add support for
# rebasing, squashing and amends while preserving tracy notes and commit chains 

# Copy the tracy hidden commit config from an old commit to a new commit
# Needed for rebases or amends (since the chain should be preserved)
update_tracy_hidden() {
    local old_sha="$1"
    local new_sha="$2"
    
    local old_hidden="$(git config --get tracy."$old_sha".hidden 2>/dev/null || true)"
    
    # If there was a hidden config, copy it to the new commit
    if [[ -n "$old_hidden" ]]; then
        git config tracy."$new_sha".hidden "$old_hidden"
    fi
}

# Merge tracy hidden configs from multiple tracy-ids when squashing
update_tracy_hidden_from_refs() {
    local tracy_ids="$1"    # All tracy-ids extracted from merged notes
    local new_sha="$2"      # The new squashed commit
    
    local first_hidden=""
    local last_hidden=""
    local chain_hiddens=()
    
    while IFS= read -r tracy_id; do
        [[ -z "$tracy_id" ]] && continue # Empty line
        
        # Construct the ref path for this tracy-id
        local ref="refs/tracy/$tracy_id"
        
        # Check if this ref exists in the repo
        if git rev-parse --verify "$ref" >/dev/null 2>&1; then
            # Get the actual commit hash that this ref points to
            local hidden=$(git rev-parse "$ref^{commit}" 2>/dev/null || true)
            
            if [[ -n "$hidden" ]]; then
                if [[ -z "$first_hidden" ]]; then
                    first_hidden="$hidden"
                fi
                
                last_hidden="$hidden"
                chain_hiddens+=("$hidden")
            fi
        fi
    done <<< "$tracy_ids"
    
    # If we have multiple chains (squash), merge them together
    if [[ ${#chain_hiddens[@]} -gt 1 ]]; then
        local combined_hidden=$(combine_tracy_chains "${chain_hiddens[@]}")

        if [[ -n "$combined_hidden" ]]; then
            git config tracy."$new_sha".hidden "$combined_hidden"
        fi
    elif [[ -n "$first_hidden" ]]; then
        # Single chain case (rebase), copy the first chain
        git config tracy."$new_sha".hidden "$first_hidden"
    fi
}

# Combines two tracy chains into one by prepending
# the older chain's unique commits to the newer chain
combine_tracy_chains() {
    local chain_hiddens=("$@")
    
    local newer_head="${chain_hiddens[0]}"
    local older_head="${chain_hiddens[1]}"
    
    # Find merge base - the point where the two chains diverge
    # Commits after this point in the older chain are unique to it
    local merge_base=$(git merge-base "$newer_head" "$older_head" 2>/dev/null || true)
    
    # Get commits from older chain that are AFTER the merge base
    # These are the unique commits we need to prepend
    local older_commits=()
    if [[ -n "$merge_base" ]]; then
        # Get commits from older_head back to (but not including) merge_base
        while IFS= read -r commit_hash; do
            if [[ "$commit_hash" == "$merge_base" ]]; then
                break
            fi
            older_commits+=("$commit_hash")
        done < <(git log --format="%h" "$older_head" 2>/dev/null)
    else
        # No merge base found (shouldn't happen), just use all older commits
        while IFS= read -r commit_hash; do
            older_commits+=("$commit_hash")
        done < <(git log --format="%h" "$older_head" 2>/dev/null)
    fi
    
    # If no unique commits in older chain, just return newer
    if [[ ${#older_commits[@]} -eq 0 ]]; then
        echo "$newer_head"
        return
    fi
    
    # Start with the newer chain
    local current_head="$newer_head"
    
    # Prepend older commits in reverse order (iterate backwards through array)
    # This puts them in chronological order: oldest first
    for ((i=${#older_commits[@]}-1; i>=0; i--)); do
        local commit_hash="${older_commits[$i]}"
        
        # Get the tree for this commit
        local commit_tree=$(git rev-parse "$commit_hash^{tree}" 2>/dev/null || true)
        
        # Skip if we can't get the tree
        if [[ -z "$commit_tree" ]]; then
            continue
        fi
        
        # Create new commit with older chain's tree and newer chain as parent
        local new_commit
        new_commit=$(GIT_AUTHOR_NAME="Tracybot" GIT_AUTHOR_EMAIL="Tracybot@local" \
                    git commit-tree -p "$current_head" "$commit_tree" -m "Merged tracy chain" 2>/dev/null || true)
        
        # If commit was created, update our current head
        if [[ -n "$new_commit" ]]; then
            current_head="$new_commit"
        else
            break
        fi
    done
    
    # Return the new combined head
    echo "$current_head"
}

while read -r old_sha new_sha; do 
    old_note="$(git notes show "$old_sha" 2>/dev/null || true)"
    new_note="$(git notes show "$new_sha" 2>/dev/null || true)"

    # Neither has a note
    if [[ -z "$old_note" && -z "$new_note" ]]; then
        continue
    fi
    
    # Only old commit has a note (e.g., rebase onto a commit with no history)
    # Copy the note and update hidden config
    if [[ -n "$old_note" && -z "$new_note" ]]; then
        printf "%s\n" "$old_note" | git notes add -f -F - "$new_sha"
        update_tracy_hidden "$old_sha" "$new_sha"
        continue
    fi

    # Only new commit has note
    if [[ -z "$old_note" && -n "$new_note" ]]; then
        continue
    fi

    # Both commits have notes
    merged_note="$new_note"$'\n'"$old_note"
    printf "%s\n" "$merged_note" | git notes add -f -F - "$new_sha"
    
    old_tracy_ids=$(echo "$old_note" | grep -oE 'tracy-id: [a-f0-9-]+' | cut -d' ' -f2)
    new_tracy_ids=$(echo "$new_note" | grep -oE 'tracy-id: [a-f0-9-]+' | cut -d' ' -f2)
    all_tracy_ids="$new_tracy_ids"$'\n'"$old_tracy_ids"

    update_tracy_hidden_from_refs "$all_tracy_ids" "$new_sha"
done