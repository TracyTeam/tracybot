{
  "name": "tracybot-extension",
  "displayName": "Tracybot",
  "version": "1.1.2",
  "publisher": "TracyTeam",
  "description": "Tracing agent prompts to code",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "tracy",
    "ai",
    "blame",
    "git",
    "prompt-tracing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TracyTeam/tracybot.git"
  },
  "bugs": {
    "url": "https://github.com/TracyTeam/tracybot/issues"
  },
  "homepage": "https://github.com/TracyTeam/tracybot/blob/main/vscode-extension/README.md",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tracybot-extension.blameAI",
        "title": "Tracybot: Open AI Blame window"
      },
      {
        "command": "tracybot-extension.invalidateCache",
        "title": "Tracybot: Invalidate History Cache"
      }
    ],
    "keybindings": [
      {
        "command": "tracybot-extension.blameAI",
        "key": "ctrl+shift+0",
        "mac": "cmd+shift+0",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "clean": "rm -rf out assets init.py tracking",
    "copy-assets": "mkdir -p assets && cp ../init.py assets/ && cp -r ../tracking assets/",
    "vscode:prepublish": "npm run clean && npm run compile && npm run copy-assets",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package -o out/tracybot-extension.vsix",
    "deploy": "npm run package && code --install-extension out/tracybot-extension.vsix"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.9.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "bleu-score": "^1.0.4",
    "marked": "^4.3.0",
    "p-limit": "^3.1.0",
    "zod": "^4.3.6"
  }
}
